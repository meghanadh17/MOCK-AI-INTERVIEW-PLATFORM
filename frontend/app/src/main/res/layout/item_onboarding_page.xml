<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@android:color/transparent">

    <!-- Brand icon container (Premium card squircle) -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_marginBottom="48dp"
        app:cardBackgroundColor="#0D0D11"
        app:cardCornerRadius="36dp"
        app:cardElevation="12dp"
        app:strokeColor="#1E1E24"
        app:strokeWidth="1.5dp">

        <ImageView
            android:id="@+id/iv_illustration"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_interview"
            android:contentDescription="Slide Illustration" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Slide Title -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Title"
        android:textAppearance="@style/TextAppearance.App.Display"
        android:textColor="@color/text_prim"
        android:textSize="28sp"
        android:gravity="center" />

    <!-- Slide Description -->
    <TextView
        android:id="@+id/tv_description"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Description"
        android:textAppearance="@style/TextAppearance.App.Body"
        android:textColor="@color/text_sec"
        android:lineSpacingExtra="4dp"
        android:gravity="center" />

</LinearLayout>
