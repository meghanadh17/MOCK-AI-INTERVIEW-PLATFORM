<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_void"
    android:scrollbars="none"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <!-- Header row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="@dimen/card_icon_size"
                android:layout_height="@dimen/card_icon_size"
                android:background="@drawable/bg_button_neo"
                android:src="@drawable/ic_arrow_back"
                android:scaleType="center"
                android:contentDescription="Back"
                app:tint="@color/text_muted" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_md"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_breadcrumb"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SESSIONS Â· PROGRESS"
                    android:textAppearance="@style/TextAppearance.App.Label" />

                <TextView
                    android:id="@+id/tv_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Your Progress"
                    android:textAppearance="@style/TextAppearance.App.Heading"
                    android:singleLine="true"
                    android:ellipsize="end" />
            </LinearLayout>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="@dimen/spacing_sm"
            android:background="@color/border_subtle" />

        <!-- 1. Streak Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            style="@style/Widget.App.Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- Flame Icon (replaced remote Lottie to avoid 403 crash) -->
                    <TextView
                        android:id="@+id/lottie_flame"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:text="🔥"
                        android:textSize="32sp"
                        android:gravity="center" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_streak_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="STREAK ACTIVE"
                            android:textAppearance="@style/TextAppearance.App.Label"
                            android:textColor="@color/score_mid" />

                        <TextView
                            android:id="@+id/tv_streak_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 Days Practice"
                            android:textAppearance="@style/TextAppearance.App.Title"
                            android:textColor="@color/text_prim" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Horizontal 7-Day calendar strip -->
                <LinearLayout
                    android:id="@+id/layout_calendar_strip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="@dimen/spacing_md" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 2. Progress Chart Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            style="@style/Widget.App.Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/spacing_md">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Score Progression"
                        android:textAppearance="@style/TextAppearance.App.Title"
                        android:textColor="@color/text_prim" />

                    <!-- Date Range Chips (1W|1M|3M|All) -->
                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_range"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_1w"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1W"
                            style="@style/Widget.App.Chip" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_1m"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1M"
                            style="@style/Widget.App.Chip" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_3m"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3M"
                            style="@style/Widget.App.Chip" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_all"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ALL"
                            style="@style/Widget.App.Chip" />
                    </com.google.android.material.chip.ChipGroup>
                </LinearLayout>

                <!-- Custom LineChartView -->
                <com.aiinterview.presentation.sessions.view.LineChartView
                    android:id="@+id/line_chart"
                    android:layout_width="match_parent"
                    android:layout_height="220dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 3. Weak Areas List (Orange accent) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="@dimen/spacing_md">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Top Focus Areas"
                android:textAppearance="@style/TextAppearance.App.Title"
                android:textColor="@color/score_mid"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <LinearLayout
                android:id="@+id/layout_weak_areas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>

        <!-- 4. Strengths List (Emerald accent) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Top Key Strengths"
                android:textAppearance="@style/TextAppearance.App.Title"
                android:textColor="@color/score_high"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <LinearLayout
                android:id="@+id/layout_strengths"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
