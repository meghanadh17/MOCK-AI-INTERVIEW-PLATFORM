<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_void"
        android:scrollbars="none"
        android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <!-- Header row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="@dimen/card_icon_size"
                android:layout_height="@dimen/card_icon_size"
                android:background="@drawable/bg_button_neo"
                android:src="@drawable/ic_arrow_back"
                android:scaleType="center"
                android:contentDescription="Back"
                app:tint="@color/text_muted" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_md"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_breadcrumb"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SESSION Â· DETAIL"
                    android:textAppearance="@style/TextAppearance.App.Label" />

                <TextView
                    android:id="@+id/tv_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Session Review"
                    android:textAppearance="@style/TextAppearance.App.Heading"
                    android:singleLine="true"
                    android:ellipsize="end" />
            </LinearLayout>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="@dimen/spacing_sm"
            android:background="@color/border_subtle" />

        <!-- Tabs -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_sm"
            style="@style/Widget.App.Tab" />

        <!-- Action Buttons (Share & Export) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/spacing_md">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_share"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Share"
                app:icon="@drawable/ic_share"
                app:iconSize="16dp"
                app:iconGravity="textStart"
                android:layout_marginEnd="@dimen/spacing_xs"
                style="@style/Widget.App.Button.Outline" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_export"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Export"
                app:icon="@drawable/ic_upload"
                app:iconSize="16dp"
                app:iconGravity="textStart"
                android:layout_marginStart="@dimen/spacing_xs"
                style="@style/Widget.App.Button.Zinc" />
        </LinearLayout>

        <!-- Dynamic Content Swap Frame -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- TAB 1: Summary -->
            <LinearLayout
                android:id="@+id/layout_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <!-- Overall Grade Badge Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md"
                    style="@style/Widget.App.Card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_score_label"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="OVERALL EVALUATION SCORE"
                            android:textAppearance="@style/TextAppearance.App.Label" />

                        <TextView
                            android:id="@+id/tv_detail_score"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="6dp"
                            android:background="@drawable/shape_score_badge"
                            android:textAppearance="@style/TextAppearance.App.Mono"
                            android:textSize="18sp"
                            android:text="0.0" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- AI narrative summary -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md"
                    style="@style/Widget.App.Card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AI Narrative Summary"
                            android:textAppearance="@style/TextAppearance.App.Title"
                            android:textColor="@color/text_prim"
                            android:layout_marginBottom="@dimen/spacing_sm" />

                        <TextView
                            android:id="@+id/tv_ai_summary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.App.Body" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- What Went Well list -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md"
                    style="@style/Widget.App.Card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="What Went Well"
                            android:textAppearance="@style/TextAppearance.App.Title"
                            android:textColor="@color/score_high"
                            android:layout_marginBottom="@dimen/spacing_sm" />

                        <TextView
                            android:id="@+id/tv_what_went_well"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.App.Body" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- What to Improve list -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md"
                    style="@style/Widget.App.Card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="What to Improve"
                            android:textAppearance="@style/TextAppearance.App.Title"
                            android:textColor="@color/score_mid"
                            android:layout_marginBottom="@dimen/spacing_sm" />

                        <TextView
                            android:id="@+id/tv_what_to_improve"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.App.Body" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- TAB 2: Score -->
            <LinearLayout
                android:id="@+id/layout_score"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Radar chart card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md"
                    style="@style/Widget.App.Card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="start"
                            android:text="Dimensions Radar Chart"
                            android:textAppearance="@style/TextAppearance.App.Title"
                            android:textColor="@color/text_prim"
                            android:layout_marginBottom="@dimen/spacing_md" />

                        <com.aiinterview.presentation.sessions.view.RadarChartView
                            android:id="@+id/radar_chart"
                            android:layout_width="280dp"
                            android:layout_height="280dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Detailed progress rows -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md"
                    style="@style/Widget.App.Card">

                    <LinearLayout
                        android:id="@+id/layout_score_dimensions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- TAB 3: Improvements -->
            <LinearLayout
                android:id="@+id/layout_improvements"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Title card -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Personalized Study Plan (30 Days)"
                    android:textAppearance="@style/TextAppearance.App.Title"
                    android:textColor="@color/text_prim"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Complete the following actionable checklist tasks customized based on your weakness areas."
                    android:textAppearance="@style/TextAppearance.App.BodySmall"
                    android:textColor="@color/text_muted"
                    android:layout_marginBottom="@dimen/spacing_md" />

                <!-- Actionable Checklist Recycler -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_checklist"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never" />
            </LinearLayout>
        </FrameLayout>

    </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include layout="@layout/layout_loading_overlay" />

</FrameLayout>
