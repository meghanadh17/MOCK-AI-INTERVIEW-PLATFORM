<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_void"
    android:fitsSystemWindows="true">

    <!-- AppBar Area -->
    <LinearLayout
        android:id="@+id/layout_app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/spacing_md"
        android:paddingTop="@dimen/spacing_md"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Timer Chip Left -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/shape_pill_badge"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_timer"
                    app:tint="#A1A1AA"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/tv_timer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="20:00"
                    android:textAppearance="@style/TextAppearance.App.Mono"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Question Counter Chip Right -->
            <TextView
                android:id="@+id/tv_question_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/shape_pill_badge"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="Q 1/5"
                android:textAppearance="@style/TextAppearance.App.Mono"
                android:textColor="#818CF8" />
        </LinearLayout>

        <!-- Session Progress Indicator -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/session_progress_bar"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="12dp"
            app:trackColor="#1F1F2E"
            app:indicatorColor="@color/primary"
            app:trackCornerRadius="2dp"
            android:progress="20" />

        <!-- Question Grid/List Selector -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_question_dots"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            android:overScrollMode="never"
            android:paddingBottom="4dp" />
    </LinearLayout>

    <!-- Question Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_question"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="@dimen/spacing_md"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="12dp"
        style="@style/Widget.App.Card"
        app:cardBackgroundColor="@color/bg_surface"
        app:strokeColor="@color/border_def"
        app:strokeWidth="1dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/layout_app_bar"
        app:layout_constraintBottom_toTopOf="@id/card_answer"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Category & Difficulty Chips Row inside Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tv_question_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/shape_pill_badge"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="TECHNICAL"
                    android:textAppearance="@style/TextAppearance.App.Label"
                    android:textColor="#818CF8"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tv_question_difficulty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/shape_pill_badge"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="MEDIUM"
                    android:textAppearance="@style/TextAppearance.App.Label"
                    android:textColor="#10B981"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Scrollable Question Text -->
            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:scrollbars="none"
                android:fillViewport="true">

                <TextView
                    android:id="@+id/tv_question"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Loading question..."
                    android:textAppearance="@style/TextAppearance.App.Body"
                    android:textColor="@color/text_prim"
                    android:textSize="16sp"
                    android:lineSpacingMultiplier="1.5" />
            </androidx.core.widget.NestedScrollView>

            <!-- Collapsible Hint Section -->
            <LinearLayout
                android:id="@+id/layout_hint_collapsible"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_hint"
                android:padding="12dp">

                <TextView
                    android:id="@+id/tv_hint_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.App.BodySmall"
                    android:textColor="#FDE68A"
                    android:lineSpacingMultiplier="1.3" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Answer Input Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_answer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/spacing_md"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="#0D0D14"
        app:strokeColor="@color/border_def"
        app:strokeWidth="1dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/card_question"
        app:layout_constraintBottom_toTopOf="@id/layout_bottom_bar"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp">

            <EditText
                android:id="@+id/et_answer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:minHeight="120dp"
                android:maxHeight="160dp"
                android:gravity="top|start"
                android:background="@null"
                android:hint="Type your response here..."
                android:textColorHint="@color/text_muted"
                android:inputType="textMultiLine"
                android:textAppearance="@style/TextAppearance.App.Body"
                android:textColor="@color/text_prim"
                android:textSize="14sp"
                android:layout_marginEnd="8dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@id/tv_char_counter"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toLeftOf="@id/fab_voice" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab_voice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_mic"
                app:fabCustomSize="40dp"
                app:maxImageSize="20dp"
                app:tint="#0D0D12"
                app:backgroundTint="#FFFFFF"
                app:elevation="2dp"
                android:contentDescription="Voice Input"
                app:layout_constraintBottom_toBottomOf="@id/et_answer"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintLeft_toRightOf="@id/et_answer" />

            <!-- Character Counter -->
            <TextView
                android:id="@+id/tv_char_counter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="0 characters"
                android:textAppearance="@style/TextAppearance.App.BodySmall"
                android:textColor="@color/text_muted"
                app:layout_constraintTop_toBottomOf="@id/et_answer"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toLeftOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Bottom Action Bar -->
    <LinearLayout
        android:id="@+id/layout_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/spacing_md"
        android:paddingBottom="16dp"
        android:paddingTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/card_answer"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <!-- End Session Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_end"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/button_height"
            android:text="End"
            style="@style/Widget.App.Button.Ghost"
            app:icon="@drawable/ic_close"
            android:textColor="@color/destructive"
            app:iconTint="@color/destructive" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Hint Action Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_hint"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/button_height"
            android:text="Hint"
            style="@style/Widget.App.Button.Ghost"
            app:icon="@drawable/ic_hint"
            app:iconTint="#FDE68A"
            android:textColor="#FDE68A" />

        <!-- Skip Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_skip"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/button_height"
            android:text="Skip"
            style="@style/Widget.App.Button.Ghost"
            app:icon="@drawable/ic_arrow_forward" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_submit"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/button_height"
            android:layout_marginStart="8dp"
            android:text="Submit"
            style="@style/Widget.App.Button.Zinc" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_next"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/button_height"
            android:layout_marginStart="8dp"
            android:text="Next →"
            android:visibility="gone"
            style="@style/Widget.App.Button.Primary"
            app:icon="@drawable/ic_arrow_forward"
            app:iconGravity="end" />

    </LinearLayout>

    <include layout="@layout/layout_loading_overlay" />

</androidx.constraintlayout.widget.ConstraintLayout>
