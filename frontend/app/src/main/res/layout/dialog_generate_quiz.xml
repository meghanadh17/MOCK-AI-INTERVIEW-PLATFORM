<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="20dp"
    app:cardCornerRadius="16dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/border_def"
    app:cardBackgroundColor="@color/bg_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_sparkles"
                app:tint="@color/primary"
                android:importantForAccessibility="no" />

            <TextView
                android:id="@+id/tv_dialog_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Generate AI Quiz"
                android:textAppearance="@style/TextAppearance.App.Title"
                android:textColor="@color/text_prim"
                android:textSize="16sp" />

            <ImageButton
                android:id="@+id/btn_close"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_close"
                app:tint="@color/text_muted"
                android:contentDescription="Close" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="16dp"
            android:background="@color/border_subtle" />

        <!-- Input Field: Topic -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="QUIZ TOPIC / STACK"
            android:textAppearance="@style/TextAppearance.App.Mono"
            android:textColor="@color/text_muted"
            android:textSize="10sp"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layout_topic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:hintEnabled="false"
            app:boxStrokeWidth="1dp"
            app:boxStrokeColor="@color/border_def"
            app:boxBackgroundColor="@color/bg_void"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_quiz_topic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. Kotlin Coroutines, System Design"
                android:textColor="@color/text_prim"
                android:textColorHint="@color/text_muted"
                android:inputType="text"
                android:textSize="14sp"
                android:padding="14dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Input Field: Difficulty -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DIFFICULTY LEVEL"
            android:textAppearance="@style/TextAppearance.App.Mono"
            android:textColor="@color/text_muted"
            android:textSize="10sp"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/border_def"
            app:cardBackgroundColor="@color/bg_void">

            <Spinner
                android:id="@+id/spinner_difficulty"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:paddingHorizontal="12dp"
                android:backgroundTint="@color/text_muted"
                android:spinnerMode="dropdown" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Action Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_generate_submit"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Generate Quiz"
            app:cornerRadius="12dp"
            style="@style/Widget.App.Button.Primary" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
