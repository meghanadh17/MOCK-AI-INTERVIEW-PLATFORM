<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_void">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:adjustViewBounds="true"
        android:fitsSystemWindows="true"
        android:src="@drawable/bg_auth_pattern"
        android:importantForAccessibility="no" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <!-- Breadcrumb indicator container -->
            <LinearLayout
                android:id="@+id/ll_breadcrumb"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="56dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <TextView
                    android:id="@+id/tv_breadcrumb_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AUTH"
                    android:textColor="#52525B"
                    android:textAppearance="@style/TextAppearance.App.Label" />

                <!-- Vertical block -->
                <View
                    android:layout_width="6dp"
                    android:layout_height="12dp"
                    android:layout_marginStart="8dp"
                    android:background="#52525B" />

                <!-- Horizontal line -->
                <View
                    android:layout_width="24dp"
                    android:layout_height="1dp"
                    android:layout_marginStart="6dp"
                    android:background="#27272A" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_heading"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Create Account"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:fontFamily="@font/dm_sans_bold"
                app:layout_constraintTop_toBottomOf="@id/ll_breadcrumb"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tv_subtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Join MockAI and start your AI interview preparation journey"
                android:textAppearance="@style/TextAppearance.App.Body"
                android:textColor="#71717A"
                app:layout_constraintTop_toBottomOf="@id/tv_heading"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Register form card (flat outlined card) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_form"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="36dp"
                app:cardBackgroundColor="#040406"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="#27272A"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Name Input with profile icon prefix -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/Widget.App.TextInput.Outlined"
                        android:hint="Full Name"
                        app:startIconDrawable="@drawable/ic_profile"
                        app:startIconTint="#71717A">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_name"
                            android:layout_width="match_parent"
                            android:layout_height="54dp"
                            android:inputType="textPersonName"
                            android:textColor="@color/text_prim"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Email Input with mail icon prefix -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        style="@style/Widget.App.TextInput.Outlined"
                        android:hint="Email address"
                        app:startIconDrawable="@drawable/ic_mail"
                        app:startIconTint="#71717A">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_email"
                            android:layout_width="match_parent"
                            android:layout_height="54dp"
                            android:inputType="textEmailAddress"
                            android:textColor="@color/text_prim"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Password Input with lock icon prefix -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        style="@style/Widget.App.TextInput.Outlined"
                        android:hint="Password"
                        app:startIconDrawable="@drawable/ic_lock"
                        app:startIconTint="#71717A"
                        app:endIconMode="password_toggle"
                        app:endIconTint="#71717A">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_password"
                            android:layout_width="match_parent"
                            android:layout_height="54dp"
                            android:inputType="textPassword"
                            android:textColor="@color/text_prim"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Confirm Password Input with lock icon prefix -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_confirm_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        style="@style/Widget.App.TextInput.Outlined"
                        android:hint="Confirm Password"
                        app:startIconDrawable="@drawable/ic_lock"
                        app:startIconTint="#71717A"
                        app:endIconMode="password_toggle"
                        app:endIconTint="#71717A">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_confirm_password"
                            android:layout_width="match_parent"
                            android:layout_height="54dp"
                            android:inputType="textPassword"
                            android:textColor="@color/text_prim"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Select Role"
                        android:textAppearance="@style/TextAppearance.App.Label"
                        android:textColor="#71717A" />

                    <!-- Role Selector ChipGroup -->
                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/cg_role"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:singleSelection="true"
                        app:checkedChip="@+id/chip_candidate">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_candidate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Candidate"
                            android:checkable="true"
                            app:chipBackgroundColor="@color/selector_chip_bg"
                            android:textColor="@color/selector_chip_text"
                            app:chipStrokeColor="@color/selector_chip_stroke"
                            style="@style/Widget.App.Chip" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_coach"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Interviewer Coach"
                            android:checkable="true"
                            app:chipBackgroundColor="@color/selector_chip_bg"
                            android:textColor="@color/selector_chip_text"
                            app:chipStrokeColor="@color/selector_chip_stroke"
                            style="@style/Widget.App.Chip" />
                    </com.google.android.material.chip.ChipGroup>

                    <!-- Terms and Conditions CheckBox -->
                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cb_terms"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="I agree to the Terms &amp; Conditions"
                        android:textColor="@color/text_sec"
                        android:textSize="13sp"
                        app:buttonTint="@color/selector_checkbox_tint" />

                    <!-- Register Button with custom zinc/metallic gradient background -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_register"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="24dp"
                        android:text="REGISTER"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:background="@drawable/bg_button_login_grad"
                        app:backgroundTint="@null"
                        style="@style/Widget.Material3.Button.UnelevatedButton" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Login link -->
            <TextView
                android:id="@+id/tv_login_link"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Already have an account? Login"
                android:textColor="#71717A"
                android:textSize="13sp"
                android:clickable="true"
                android:focusable="true"
                app:layout_constraintTop_toBottomOf="@id/card_form"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <include layout="@layout/layout_loading_overlay" />
</FrameLayout>
