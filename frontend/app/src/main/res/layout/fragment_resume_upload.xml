<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_void"
    android:fitsSystemWindows="true">

    <!-- Header layout -->
    <LinearLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_md"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="@dimen/card_icon_size"
            android:layout_height="@dimen/card_icon_size"
            android:background="@drawable/bg_button_neo"
            android:src="@drawable/ic_arrow_back"
            android:scaleType="center"
            android:contentDescription="Back"
            app:tint="@color/text_muted" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_md"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_breadcrumb"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RESUME · UPLOAD"
                android:textAppearance="@style/TextAppearance.App.Label" />

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Upload Resume"
                android:textAppearance="@style/TextAppearance.App.Heading" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:id="@+id/header_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_subtle"
        app:layout_constraintTop_toBottomOf="@id/layout_header" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/header_divider"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <!-- Drag & Drop Area (Simulator) -->
            <LinearLayout
                android:id="@+id/layout_drag_drop"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="@drawable/bg_dashed_upload"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:padding="20dp">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_upload"
                    app:tint="@color/text_muted"
                    android:importantForAccessibility="no" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Drag &amp; Drop your Resume PDF here"
                    android:textAppearance="@style/TextAppearance.App.Title"
                    android:textColor="@color/text_prim" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="or click to browse from device"
                    android:textAppearance="@style/TextAppearance.App.BodySmall"
                    android:textColor="@color/text_muted" />
            </LinearLayout>

            <!-- OR Divider -->
            <LinearLayout
                android:id="@+id/layout_or_divider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginVertical="20dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/border_subtle" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:paddingHorizontal="16dp"
                    android:text="OR"
                    android:textAppearance="@style/TextAppearance.App.Label"
                    android:textColor="@color/text_muted" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/border_subtle" />
            </LinearLayout>

            <!-- Browse Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_browse"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:text="Browse PDF File"
                style="@style/Widget.App.Button.Outline"
                app:icon="@drawable/ic_resume" />

            <!-- Upload Progress Card (hidden until file is chosen) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_upload_progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:visibility="gone"
                style="@style/Widget.App.Card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_resume"
                            app:tint="@color/primary"
                            android:importantForAccessibility="no" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_upload_filename"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="filename.pdf"
                                android:textAppearance="@style/TextAppearance.App.Title"
                                android:singleLine="true"
                                android:ellipsize="end" />

                            <TextView
                                android:id="@+id/tv_upload_size"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0.0 KB"
                                android:textAppearance="@style/TextAppearance.App.BodySmall" />
                        </LinearLayout>
                    </LinearLayout>

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/upload_progress_bar"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="16dp"
                        app:trackColor="#1F1F2E"
                        app:indicatorColor="@color/primary"
                        app:trackCornerRadius="3dp"
                        android:progress="0" />

                    <TextView
                        android:id="@+id/tv_upload_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Preparing upload..."
                        android:textAppearance="@style/TextAppearance.App.BodySmall"
                        android:textColor="@color/text_sec" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Stepper Progress Panel (hidden until parsing starts) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_stepper"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:visibility="gone"
                style="@style/Widget.App.Card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Parser Progress"
                        android:textAppearance="@style/TextAppearance.App.Title" />

                    <!-- Step 1: Upload -->
                    <LinearLayout
                        android:id="@+id/layout_step_upload"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tv_step_1_num"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:background="@drawable/shape_pill_badge"
                            android:gravity="center"
                            android:text="1"
                            android:textAppearance="@style/TextAppearance.App.Mono"
                            android:textColor="#FFFFFF" />

                        <TextView
                            android:id="@+id/tv_step_1_label"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:text="Uploading file to secure vault"
                            android:textAppearance="@style/TextAppearance.App.Body" />
                    </LinearLayout>

                    <!-- Connector 1 -->
                    <View
                        android:layout_width="2dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="11dp"
                        android:background="#27272A" />

                    <!-- Step 2: Parse -->
                    <LinearLayout
                        android:id="@+id/layout_step_parse"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tv_step_2_num"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:background="@drawable/shape_pill_badge"
                            android:gravity="center"
                            android:text="2"
                            android:textAppearance="@style/TextAppearance.App.Mono"
                            android:textColor="#6B6B80" />

                        <TextView
                            android:id="@+id/tv_step_2_label"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:text="Parsing PDF contents &amp; details"
                            android:textAppearance="@style/TextAppearance.App.Body"
                            android:textColor="@color/text_muted" />
                    </LinearLayout>

                    <!-- Connector 2 -->
                    <View
                        android:layout_width="2dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="11dp"
                        android:background="#27272A" />

                    <!-- Step 3: Analyze -->
                    <LinearLayout
                        android:id="@+id/layout_step_analyze"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tv_step_3_num"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:background="@drawable/shape_pill_badge"
                            android:gravity="center"
                            android:text="3"
                            android:textAppearance="@style/TextAppearance.App.Mono"
                            android:textColor="#6B6B80" />

                        <TextView
                            android:id="@+id/tv_step_3_label"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:text="Triggering AI insights &amp; ATS checks"
                            android:textAppearance="@style/TextAppearance.App.Body"
                            android:textColor="@color/text_muted" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
