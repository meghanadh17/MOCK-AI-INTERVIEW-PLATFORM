<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bg_surface"
    android:padding="24dp">

    <!-- Handle indicator for bottom sheet -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@color/border_subtle" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Filter Jobs"
        android:textAppearance="@style/TextAppearance.App.Title"
        android:textColor="@color/text_prim"
        android:layout_marginBottom="20dp" />

    <!-- Location Input -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LOCATION"
        android:textAppearance="@style/TextAppearance.App.Label"
        android:textColor="@color/text_muted"
        android:textSize="10sp"
        android:layout_marginBottom="8dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/input_layout_location"
        style="@style/Widget.App.TextInput.Outlined"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp">

        <EditText
            android:id="@+id/et_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. San Francisco, Remote"
            android:inputType="text"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.App.Body" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Experience Level Selection -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="EXPERIENCE LEVEL"
        android:textAppearance="@style/TextAppearance.App.Label"
        android:textColor="@color/text_muted"
        android:textSize="10sp"
        android:layout_marginBottom="8dp" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_experience"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:singleSelection="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_any"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Any Experience"
            android:checked="true"
            style="@style/Widget.App.Chip" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_junior"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Junior"
            style="@style/Widget.App.Chip" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_mid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mid"
            style="@style/Widget.App.Chip" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_senior"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Senior"
            style="@style/Widget.App.Chip" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_lead"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lead"
            style="@style/Widget.App.Chip" />
    </com.google.android.material.chip.ChipGroup>

    <!-- Apply Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_apply"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:text="Apply Filters"
        style="@style/Widget.App.Button.Zinc" />
</LinearLayout>
