<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_void">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:adjustViewBounds="true"
        android:fitsSystemWindows="true"
        android:src="@drawable/bg_auth_pattern"
        android:importantForAccessibility="no" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/spacing_lg">

            <!-- Breadcrumb indicator container -->
            <LinearLayout
                android:id="@+id/ll_breadcrumb"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="56dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <TextView
                    android:id="@+id/tv_breadcrumb_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AUTH"
                    android:textColor="#52525B"
                    android:textAppearance="@style/TextAppearance.App.Label" />

                <!-- Vertical block -->
                <View
                    android:layout_width="6dp"
                    android:layout_height="12dp"
                    android:layout_marginStart="8dp"
                    android:background="#52525B" />

                <!-- Horizontal line -->
                <View
                    android:layout_width="24dp"
                    android:layout_height="1dp"
                    android:layout_marginStart="6dp"
                    android:background="#27272A" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_heading"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Verify OTP"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:fontFamily="@font/dm_sans_bold"
                app:layout_constraintTop_toBottomOf="@id/ll_breadcrumb"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tv_subtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="We have sent a 6-digit verification code to your email."
                android:textAppearance="@style/TextAppearance.App.Body"
                android:textColor="#71717A"
                app:layout_constraintTop_toBottomOf="@id/tv_heading"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Verification form card (flat outlined card) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_form"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="36dp"
                app:cardBackgroundColor="#040406"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="#27272A"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- 6-Box OTP PinView layout -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/et_otp_1"
                            android:layout_width="0dp"
                            android:layout_height="54dp"
                            android:layout_weight="1"
                            android:layout_margin="4dp"
                            android:background="@drawable/bg_otp_digit"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="1"
                            android:textColor="@color/text_prim"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textCursorDrawable="@null" />

                        <EditText
                            android:id="@+id/et_otp_2"
                            android:layout_width="0dp"
                            android:layout_height="54dp"
                            android:layout_weight="1"
                            android:layout_margin="4dp"
                            android:background="@drawable/bg_otp_digit"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="1"
                            android:textColor="@color/text_prim"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textCursorDrawable="@null" />

                        <EditText
                            android:id="@+id/et_otp_3"
                            android:layout_width="0dp"
                            android:layout_height="54dp"
                            android:layout_weight="1"
                            android:layout_margin="4dp"
                            android:background="@drawable/bg_otp_digit"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="1"
                            android:textColor="@color/text_prim"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textCursorDrawable="@null" />

                        <EditText
                            android:id="@+id/et_otp_4"
                            android:layout_width="0dp"
                            android:layout_height="54dp"
                            android:layout_weight="1"
                            android:layout_margin="4dp"
                            android:background="@drawable/bg_otp_digit"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="1"
                            android:textColor="@color/text_prim"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textCursorDrawable="@null" />

                        <EditText
                            android:id="@+id/et_otp_5"
                            android:layout_width="0dp"
                            android:layout_height="54dp"
                            android:layout_weight="1"
                            android:layout_margin="4dp"
                            android:background="@drawable/bg_otp_digit"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="1"
                            android:textColor="@color/text_prim"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textCursorDrawable="@null" />

                        <EditText
                            android:id="@+id/et_otp_6"
                            android:layout_width="0dp"
                            android:layout_height="54dp"
                            android:layout_weight="1"
                            android:layout_margin="4dp"
                            android:background="@drawable/bg_otp_digit"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="1"
                            android:textColor="@color/text_prim"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textCursorDrawable="@null" />

                    </LinearLayout>

                    <!-- Mode-Aware Reset Password Fields -->
                    <LinearLayout
                        android:id="@+id/ll_reset_fields"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_new_password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            style="@style/Widget.App.TextInput.Outlined"
                            android:hint="New Password"
                            app:startIconDrawable="@drawable/ic_lock"
                            app:startIconTint="#71717A"
                            app:endIconMode="password_toggle"
                            app:endIconTint="#71717A">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_new_password"
                                android:layout_width="match_parent"
                                android:layout_height="54dp"
                                android:inputType="textPassword"
                                android:textColor="@color/text_prim"
                                android:textSize="14sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_confirm_password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            style="@style/Widget.App.TextInput.Outlined"
                            android:hint="Confirm New Password"
                            app:startIconDrawable="@drawable/ic_lock"
                            app:startIconTint="#71717A"
                            app:endIconMode="password_toggle"
                            app:endIconTint="#71717A">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_confirm_password"
                                android:layout_width="match_parent"
                                android:layout_height="54dp"
                                android:inputType="textPassword"
                                android:textColor="@color/text_prim"
                                android:textSize="14sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                    <!-- CountDownTimer layout -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_timer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Resend code in 60s"
                            android:textColor="#71717A"
                            android:textSize="13sp"
                            android:fontFamily="@font/ibm_plex_sans_regular" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_resend"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Resend OTP"
                            android:textColor="#FAFAFA"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:visibility="gone"
                            style="@style/Widget.Material3.Button.TextButton" />

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_verify"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="24dp"
                        android:text="VERIFY CODE"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:background="@drawable/bg_button_login_grad"
                        app:backgroundTint="@null"
                        style="@style/Widget.Material3.Button.UnelevatedButton" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <include layout="@layout/layout_loading_overlay" />
</FrameLayout>
