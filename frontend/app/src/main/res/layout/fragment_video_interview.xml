<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_void">

    <!-- ConstraintLayout for Main Clean UI (Camera and controls) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Full-screen Camera Preview -->
        <androidx.camera.view.PreviewView
            android:id="@+id/camera_preview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:scaleType="fillCenter" />

        <!-- Dark Overlay gradient for readability -->
        <View
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:background="@drawable/gradient_translucent_top"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:background="@drawable/gradient_translucent_bottom"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Header Actions Layout -->
        <LinearLayout
            android:id="@+id/layout_header_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- End Session Button (Left aligned) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_end_session"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="End Session · 00:00"
                android:textColor="@color/destructive"
                app:strokeColor="@color/destructive"
                app:strokeWidth="1dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                style="@style/Widget.App.Button.Ghost" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Drawer Icon Toggle Buttons (Right aligned) -->
            <ImageButton
                android:id="@+id/btn_drawer_question"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_circle_badge"
                android:backgroundTint="@color/overlay_80"
                android:src="@drawable/ic_interview"
                app:tint="@color/text_prim"
                android:contentDescription="Toggle Question Drawer" />

            <ImageButton
                android:id="@+id/btn_drawer_telemetry"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_circle_badge"
                android:backgroundTint="@color/overlay_80"
                android:src="@drawable/ic_chart"
                app:tint="@color/text_prim"
                android:contentDescription="Toggle Telemetry HUD" />

            <ImageButton
                android:id="@+id/btn_drawer_coach"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_circle_badge"
                android:backgroundTint="@color/overlay_80"
                android:src="@drawable/ic_sparkles"
                app:tint="@color/text_prim"
                android:contentDescription="Toggle AI Coach Tips" />

        </LinearLayout>

        <!-- Redesigned, perfectly centered Mic Button -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_hold_speak"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginBottom="32dp"
            app:cardCornerRadius="36dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/primary"
            app:strokeWidth="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Click to Speak">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_mic"
                app:tint="@color/primary_foreground" />

        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 1. Question details and response Bottom Sheet (Drawer) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_question_sheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/bg_void"
        app:strokeWidth="1dp"
        app:strokeColor="@color/border_def"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_peekHeight="0dp"
        app:behavior_hideable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="24dp">

            <!-- Drag Handle -->
            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:background="@color/border_def" />

            <!-- Question Sheet Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_interview"
                    app:tint="@color/primary"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="PRACTICE QUESTION"
                    android:textAppearance="@style/TextAppearance.App.Title"
                    android:textColor="@color/text_prim"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btn_minimize_question"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_close"
                    app:tint="@color/text_muted"
                    android:contentDescription="Minimize question card" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border_def"
                android:layout_marginBottom="16dp" />

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxHeight="380dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Glass Question Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_question_overlay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/bg_void"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/border_def"
                        android:layout_marginBottom="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <com.google.android.material.progressindicator.LinearProgressIndicator
                                android:id="@+id/question_progress_bar"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:max="5"
                                android:progress="1"
                                app:trackColor="#1AFFFFFF"
                                app:indicatorColor="@color/primary"
                                app:trackThickness="4dp" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="16dp">

                                <TextView
                                    android:id="@+id/tv_question_index"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Question 1 of 5"
                                    android:textAppearance="@style/TextAppearance.App.Label"
                                    android:textColor="@color/text_sec" />

                                <LinearLayout
                                    android:id="@+id/layout_question_content"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/tv_question_text"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="6dp"
                                        android:text="Loading practice question..."
                                        android:textAppearance="@style/TextAppearance.App.Title"
                                        android:textColor="@color/text_prim" />

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="12dp"
                                        android:orientation="horizontal"
                                        android:gravity="end">

                                        <com.google.android.material.button.MaterialButton
                                            android:id="@+id/btn_hint"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="AI Hint"
                                            app:icon="@drawable/ic_sparkles"
                                            app:iconSize="16dp"
                                            app:iconTint="@color/primary"
                                            android:textColor="@color/primary"
                                            style="@style/Widget.App.Button.Ghost"
                                            android:insetTop="0dp"
                                            android:insetBottom="0dp"
                                            android:textSize="12sp"
                                            android:layout_marginEnd="8dp" />

                                        <com.google.android.material.button.MaterialButton
                                            android:id="@+id/btn_type_toggle"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="Type Answer"
                                            app:icon="@drawable/ic_settings"
                                            app:iconSize="16dp"
                                            app:iconTint="@color/text_sec"
                                            android:textColor="@color/text_sec"
                                            style="@style/Widget.App.Button.Ghost"
                                            android:insetTop="0dp"
                                            android:insetBottom="0dp"
                                            android:textSize="12sp" />
                                    </LinearLayout>
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Collapsible AI Hint Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_hint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:visibility="gone"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/bg_void"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/border_def">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:src="@drawable/ic_sparkles"
                                    app:tint="@color/primary" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_weight="1"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="6dp"
                                    android:text="AI Coaching Hint"
                                    android:textAppearance="@style/TextAppearance.App.Label"
                                    android:textColor="@color/primary" />

                                <ImageButton
                                    android:id="@+id/btn_close_hint"
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:background="@android:color/transparent"
                                    android:src="@drawable/ic_close"
                                    app:tint="@color/text_muted" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tv_hint_text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="Fetching hint..."
                                android:textAppearance="@style/TextAppearance.App.BodySmall"
                                android:textColor="@color/text_prim" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Collapsible Text Input Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_text_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:visibility="gone"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/bg_void"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/border_def">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Your Answer Transcript"
                                app:hintTextColor="@color/text_muted"
                                app:boxStrokeColor="@color/selector_input_stroke"
                                style="@style/Widget.App.TextInput.Outlined">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/et_answer"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:minLines="3"
                                    android:gravity="top|start"
                                    android:inputType="textMultiLine"
                                    android:textColor="@color/text_prim" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_submit_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="end"
                                android:layout_marginTop="8dp"
                                android:text="Submit Answer"
                                style="@style/Widget.App.Button.Outline" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Glass Live Evaluation Feedback Overlay -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_evaluation_overlay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="@color/bg_void"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/border_def">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@drawable/ic_sparkles"
                                    app:tint="@color/score_high" />

                                <TextView
                                    android:id="@+id/tv_evaluation_title"
                                    android:layout_width="0dp"
                                    android:layout_weight="1"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:text="Evaluation: 8.5 / 10"
                                    android:textAppearance="@style/TextAppearance.App.Title"
                                    android:textColor="@color/text_prim"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tv_evaluation_feedback"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Feedback details..."
                                android:textAppearance="@style/TextAppearance.App.Body"
                                android:textColor="@color/text_sec" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_next_question"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="16dp"
                                android:text="Next Question"
                                style="@style/Widget.App.Button.Outline" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 2. Live Telemetry HUD Bottom Sheet (Drawer) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_telemetry_drawer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/bg_void"
        app:strokeWidth="1dp"
        app:strokeColor="@color/border_def"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_peekHeight="0dp"
        app:behavior_hideable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@color/bg_surface"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <!-- Drag Handle -->
            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:background="@color/border_def" />

            <!-- Drawer Header -->
            <LinearLayout
                android:id="@+id/layout_drawer_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="4dp"
                android:paddingBottom="12dp"
                android:background="?android:attr/selectableItemBackground">

                <ImageView
                    android:id="@+id/iv_drawer_toggle_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chart"
                    app:tint="@color/primary"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="LIVE TELEMETRY HUD"
                    android:textAppearance="@style/TextAppearance.App.Title"
                    android:textColor="@color/text_prim"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btn_close_drawer"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_close"
                    app:tint="@color/text_muted" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border_def"
                android:layout_marginBottom="16dp" />

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true"
                android:background="@color/bg_surface"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/bg_surface">

                    <!-- Posture Live Graph Card -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="POSTURE ALIGNMENT HISTORY"
                        android:textAppearance="@style/TextAppearance.App.Label"
                        android:textColor="@color/text_sec"
                        android:layout_marginTop="8dp" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="8dp"
                        app:cardBackgroundColor="@color/bg_void"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/border_def">

                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/chart_posture"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Eye Gaze Radar Tracking -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EYE GAZE COORDINATE RADAR"
                        android:textAppearance="@style/TextAppearance.App.Label"
                        android:textColor="@color/text_sec"
                        android:layout_marginTop="12dp" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp"
                        app:cardCornerRadius="60dp"
                        app:cardBackgroundColor="@color/bg_void"
                        app:strokeWidth="2dp"
                        app:strokeColor="@color/border_def">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:layout_gravity="center_vertical"
                                android:background="@color/border_def" />

                            <View
                                android:layout_width="1dp"
                                android:layout_height="match_parent"
                                android:layout_gravity="center_horizontal"
                                android:background="@color/border_def" />

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                android:layout_gravity="center"
                                app:cardCornerRadius="30dp"
                                app:cardBackgroundColor="@android:color/transparent"
                                app:strokeWidth="1dp"
                                app:strokeColor="@color/border_def" />

                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/iv_gaze_dot"
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:layout_gravity="center"
                                app:cardCornerRadius="6dp"
                                app:cardBackgroundColor="@android:color/white"
                                app:cardElevation="2dp" />
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Gaze Focus Timeline -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GAZE FOCUS TIMELINE"
                        android:textAppearance="@style/TextAppearance.App.Label"
                        android:textColor="@color/text_sec"
                        android:layout_marginTop="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="0s"
                            android:textSize="10sp"
                            android:textColor="@color/text_muted" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="15s"
                            android:textSize="10sp"
                            android:textColor="@color/text_muted"
                            android:layout_marginEnd="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="30s"
                            android:textSize="10sp"
                            android:textColor="@color/text_muted"
                            android:layout_marginEnd="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="45s"
                            android:textSize="10sp"
                            android:textColor="@color/text_muted"
                            android:layout_marginEnd="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="60s"
                            android:textSize="10sp"
                            android:textColor="@color/text_muted" />
                    </LinearLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="8dp"
                        app:cardCornerRadius="8dp"
                        app:cardBackgroundColor="@color/bg_void"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/border_def">

                        <com.aiinterview.presentation.video.view.GazeFocusBarView
                            android:id="@+id/chart_gaze"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Timeline Legend -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:src="@drawable/legend_dot_focused"
                            android:layout_gravity="center_vertical" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Focused"
                            android:textColor="@color/text_sec"
                            android:textSize="10sp"
                            android:layout_marginStart="3dp"
                            android:layout_marginEnd="6dp" />

                        <ImageView
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:src="@drawable/legend_dot_neutral"
                            android:layout_gravity="center_vertical" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Neutral"
                            android:textColor="@color/text_sec"
                            android:textSize="10sp"
                            android:layout_marginStart="3dp"
                            android:layout_marginEnd="6dp" />

                        <ImageView
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:src="@drawable/legend_dot_distracted"
                            android:layout_gravity="center_vertical" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Distracted"
                            android:textColor="@color/text_sec"
                            android:textSize="10sp"
                            android:layout_marginStart="3dp" />
                    </LinearLayout>

                    <!-- Emotion Heat State -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ACTIVE EXPRESSION FLOW"
                        android:textAppearance="@style/TextAppearance.App.Label"
                        android:textColor="@color/text_sec"
                        android:layout_marginTop="12dp" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_drawer_emotion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="24dp"
                        app:cardCornerRadius="10dp"
                        app:cardBackgroundColor="@color/bg_void"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/border_def">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="12dp">

                            <ImageView
                                android:id="@+id/iv_drawer_emotion_icon"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_sparkles"
                                app:tint="@color/primary"
                                android:layout_gravity="center_vertical" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginStart="10dp"
                                android:layout_marginEnd="8dp">

                                <TextView
                                    android:id="@+id/tv_drawer_emotion"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Neutral Expression"
                                    android:textAppearance="@style/TextAppearance.App.Body"
                                    android:textColor="@color/text_prim"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tv_drawer_emotion_subtitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="Calm · Attentive · Engaged"
                                    android:textAppearance="@style/TextAppearance.App.BodySmall"
                                    android:textColor="@color/text_sec"
                                    android:textSize="11sp" />
                            </LinearLayout>

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_arrow_forward"
                                app:tint="@color/text_muted"
                                android:layout_gravity="center_vertical" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 3. AI Coach Suggestions Bottom Sheet (Drawer) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_coach_sheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/bg_void"
        app:strokeWidth="1dp"
        app:strokeColor="@color/border_def"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_peekHeight="0dp"
        app:behavior_hideable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="24dp">

            <!-- Drag Handle -->
            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:background="@color/border_def" />

            <!-- Drawer Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_sparkles"
                    app:tint="@color/primary"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="AI COACH TIPS"
                    android:textAppearance="@style/TextAppearance.App.Title"
                    android:textColor="@color/text_prim"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btn_close_coach_sheet"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_close"
                    app:tint="@color/text_muted"
                    android:contentDescription="Close Coach Suggestions" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border_def"
                android:layout_marginBottom="16dp" />

            <!-- Tip Details -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_coach_tip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bg_void"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border_def">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_sparkles"
                        app:tint="@color/score_high" />

                    <TextView
                        android:id="@+id/tv_coach_tip"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="12dp"
                        android:text="Good composure! Keep looking straight at the camera."
                        android:textAppearance="@style/TextAppearance.App.Body"
                        android:textColor="@color/text_prim" />

                    <ImageButton
                        android:id="@+id/btn_dismiss_coach"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="@android:color/transparent"
                        android:src="@drawable/ic_close"
                        app:tint="@color/text_muted"
                        android:contentDescription="Dismiss Tip" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <include layout="@layout/layout_loading_overlay" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
