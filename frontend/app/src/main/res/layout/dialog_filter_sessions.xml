<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bg_surface"
    android:padding="24dp">

    <!-- Handle indicator for bottom sheet -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@color/border_subtle" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Filter Sessions"
        android:textAppearance="@style/TextAppearance.App.Title"
        android:textColor="@color/text_prim"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FILTER BY INTERVIEW TYPE"
        android:textAppearance="@style/TextAppearance.App.Label"
        android:textColor="@color/text_muted"
        android:textSize="10sp"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/rg_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp">

        <RadioButton
            android:id="@+id/rb_all"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="All Sessions"
            android:textColor="@color/text_sec"
            android:buttonTint="@color/primary"
            android:checked="true" />

        <RadioButton
            android:id="@+id/rb_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Text Mock Interviews"
            android:textColor="@color/text_sec"
            android:buttonTint="@color/primary" />

        <RadioButton
            android:id="@+id/rb_video"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Video Sessions"
            android:textColor="@color/text_sec"
            android:buttonTint="@color/primary" />
    </RadioGroup>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_apply"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:text="Apply Filters"
        style="@style/Widget.App.Button.Zinc" />
</LinearLayout>
