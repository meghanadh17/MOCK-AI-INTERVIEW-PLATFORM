<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_void"
    android:fitsSystemWindows="true">

    <!-- AppBar / Header Area -->
    <LinearLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/spacing_md"
        android:paddingTop="@dimen/spacing_md"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Timer Badge -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/shape_pill_badge"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_timer"
                    app:tint="@color/text_muted"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/tv_timer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="05:00"
                    android:textAppearance="@style/TextAppearance.App.Mono"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Question Progress Badge -->
            <TextView
                android:id="@+id/tv_question_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/shape_pill_badge"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="Q 1/5"
                android:textAppearance="@style/TextAppearance.App.Mono"
                android:textColor="#818CF8" />
        </LinearLayout>

        <!-- Timer Progress Indicator -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/timer_progress_bar"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="12dp"
            app:trackColor="#1F1F2E"
            app:indicatorColor="@color/score_high"
            app:trackCornerRadius="2dp"
            android:progress="100" />
    </LinearLayout>

    <!-- Scrollable Question & Option content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_question_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/layout_header"
        app:layout_constraintBottom_toTopOf="@id/layout_footer">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/spacing_md">

            <!-- Question Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_question"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.App.Card"
                app:strokeColor="@color/border_subtle"
                app:strokeWidth="1dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/bg_surface"
                app:contentPadding="0dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="QUESTION"
                        android:textAppearance="@style/TextAppearance.App.Label"
                        android:textColor="#818CF8"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tv_question"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Loading question..."
                        android:textColor="#FAFAFA"
                        android:textSize="16sp"
                        android:fontFamily="@font/ibm_plex_sans_medium"
                        android:lineSpacingMultiplier="1.4" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Quiz Option Choices list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_options"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Inline Feedback scroll container -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/layout_feedback_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        android:layout_marginTop="12dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/layout_header"
        app:layout_constraintBottom_toTopOf="@id/layout_footer">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/spacing_md"
            android:paddingBottom="24dp">

            <!-- Question Review Card in Feedback -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.App.Card"
                app:strokeColor="@color/border_subtle"
                app:strokeWidth="1dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/bg_surface"
                app:contentPadding="0dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="QUESTION"
                        android:textAppearance="@style/TextAppearance.App.Label"
                        android:textColor="@color/text_muted"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_feedback_question_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#E4E4E7"
                        android:textSize="14sp"
                        android:fontFamily="@font/ibm_plex_sans_medium"
                        android:lineSpacingMultiplier="1.3" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Result Status Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_feedback_result_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border_def"
                app:cardBackgroundColor="@color/bg_surface"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tv_feedback_result_icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✅"
                        android:textSize="40sp" />

                    <TextView
                        android:id="@+id/tv_feedback_result_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Correct!"
                        android:textAppearance="@style/TextAppearance.App.Title"
                        android:textSize="18sp"
                        android:textColor="@color/text_prim" />

                    <TextView
                        android:id="@+id/tv_feedback_result_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Great job!"
                        android:textAppearance="@style/TextAppearance.App.BodySmall"
                        android:textColor="@color/text_muted" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Your Answer Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_feedback_your_answer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.App.Card"
                app:strokeColor="@color/border_subtle"
                app:strokeWidth="1dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="@color/bg_surface"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_quiz"
                            app:tint="@color/text_muted"
                            android:importantForAccessibility="no" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="YOUR ANSWER"
                            android:textAppearance="@style/TextAppearance.App.Mono"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_feedback_your_answer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.App.Body"
                        android:textColor="@color/text_prim"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.3" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Correct Answer Card (visible only when wrong) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/layout_feedback_correct_answer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.App.Card"
                app:strokeColor="@color/score_high"
                app:strokeWidth="1dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#14352A"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_check"
                            app:tint="@color/score_high"
                            android:importantForAccessibility="no" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="CORRECT ANSWER"
                            android:textAppearance="@style/TextAppearance.App.Mono"
                            android:textColor="@color/score_high"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_feedback_correct_answer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.App.Body"
                        android:textColor="@color/score_high"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.3" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- AI Explanation Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/layout_feedback_explanation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.App.Card"
                app:strokeColor="@color/border_def"
                app:strokeWidth="1dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="@color/bg_surface"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_hint"
                            app:tint="@color/color_video"
                            android:importantForAccessibility="no" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="AI EXPLANATION"
                            android:textAppearance="@style/TextAppearance.App.Mono"
                            android:textColor="@color/color_video"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_feedback_explanation_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.App.Body"
                        android:textColor="@color/text_sec"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.4" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Footer Controls -->
    <LinearLayout
        android:id="@+id/layout_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/spacing_md"
        android:paddingBottom="16dp"
        android:paddingTop="8dp"
        android:background="@color/bg_void"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Skip / Quit Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_quit"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/button_height"
            android:text="Quit"
            style="@style/Widget.App.Button.Ghost"
            android:textColor="@color/destructive"
            app:icon="@drawable/ic_close"
            app:iconTint="@color/destructive" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Next / Submit Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_action"
            android:layout_width="160dp"
            android:layout_height="@dimen/button_height"
            android:text="Submit"
            android:enabled="false"
            style="@style/Widget.App.Button.Zinc" />
    </LinearLayout>

    <include layout="@layout/layout_loading_overlay" />

</androidx.constraintlayout.widget.ConstraintLayout>
