<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Item 1: Radial Glow focused at top center -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="300dp"
                android:centerX="0.5"
                android:centerY="0.0"
                android:startColor="#2BFAFAFA"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>

    <!-- Item 2: Grid Lines Vector -->
    <item android:drawable="@drawable/bg_inverted_pyramid_grid" />

    <!-- Item 3: Linear Gradient Overlay to fade grid and glow into void background -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="@android:color/transparent"
                android:centerColor="#80030507"
                android:endColor="#FF030507" />
        </shape>
    </item>
</layer-list>
